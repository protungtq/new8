---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleItem from "../../components/ArticleItem.astro";
import { slugify } from "../../utils/slugify";

const rawPosts = Object.entries(
  import.meta.glob('../../content/posts/*.md', {
    eager: true
  })
);

const posts = rawPosts
  .map(([path, post]) => {

    if (!post || !post.frontmatter) {
      return null;
    }

    const slug = path
      .split('/')
      .pop()
      .replace('.md', '');

    return {
      slug,
      frontmatter: post.frontmatter
    };

  })
  .filter(Boolean);

// generate tag pages
export async function getStaticPaths() {

  const rawPosts = Object.entries(
    import.meta.glob('../../content/posts/*.md', {
      eager: true
    })
  );

  const tagSet = new Set();

  rawPosts.forEach(([_, post]) => {

    if (!post?.frontmatter) {
      return;
    }

    const tags =
      post.frontmatter.tags || [];

    tags.forEach(tag => {

      tagSet.add(tag);

    });

  });

  return Array.from(tagSet).map(tag => ({
    params: {
      tag: slugify(tag)
    }
  }));

}

const currentTag = Astro.params.tag;

// original tag name
const originalTag =
  posts
    .flatMap(post =>
      post.frontmatter.tags || []
    )
    .find(tag =>
      slugify(tag) === currentTag
    );

// filter posts
const filteredPosts = posts.filter(post => {

  const tags =
    post.frontmatter.tags || [];

  return tags.some(
    tag =>
      slugify(tag) === currentTag
  );

});

// sort newest first
filteredPosts.sort((a, b) => {

  const dateA =
    a.frontmatter?.date || "2000-01-01";

  const dateB =
    b.frontmatter?.date || "2000-01-01";

  return new Date(dateB) - new Date(dateA);

});
---

<BaseLayout title={`${originalTag} - Game News`}>

  <main class="max-w-[1180px] mx-auto bg-white min-h-screen px-3 md:px-5 py-5">

    <div class="mb-8 border-l-4 border-red-600 pl-4">

      <h1 class="text-[28px] md:text-[40px] font-bold">

        #{originalTag}

      </h1>

      <p class="text-gray-500 mt-2">

        {filteredPosts.length} bài viết

      </p>

    </div>

    <section>

      {
        filteredPosts.map((post) => (
          <ArticleItem post={post} />
        ))
      }

    </section>

  </main>

</BaseLayout>