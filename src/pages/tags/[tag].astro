---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleItem from "../../components/ArticleItem.astro";
import SidebarAd from "../../components/SidebarAd.astro";
import { slugify } from "../../utils/slugify";

const rawPosts = Object.entries(
  import.meta.glob('../../content/posts/*.md', {
    eager: true
  })
);

const now = new Date();

// 1. Lọc và chuẩn hóa danh sách bài viết đã xuất bản
const posts = rawPosts
  .map(([path, post]) => {
    if (!post || !post.frontmatter) {
      return null;
    }
    const slug = path
      .split('/')
      .pop()
      .replace('.md', '');

    return {
      slug,
      frontmatter: post.frontmatter
    };
  })
  .filter(Boolean)
  .filter((post) => {
    if (!post.frontmatter?.date) return false;
    return new Date(post.frontmatter.date) <= now;
  });

// 2. Tạo danh sách trang tag tĩnh dựa trên các bài viết đã công khai (Đã sửa lỗi Missing parameter)
export async function getStaticPaths() {
  const now = new Date();
  const rawPosts = Object.entries(
    import.meta.glob('../../content/posts/*.md', {
      eager: true
    })
  );

  const tagSet = new Set();

  rawPosts.forEach(([_, post]) => {
    if (!post?.frontmatter?.date) return;
    if (new Date(post.frontmatter.date) > now) return;

    const tags = post.frontmatter.tags || [];
    tags.forEach(tag => {
      if (tag && tag.trim()) {
        tagSet.add(tag.trim());
      }
    });
  });

  return Array.from(tagSet)
    .map(tag => {
      const slugifiedTag = slugify(tag);
      // Nếu tag sau khi ép slug bị rỗng (do chứa kí tự lạ từ Blogspot), loại bỏ ngay để tránh sập build
      if (!slugifiedTag || slugifiedTag.trim() === "") {
        return null;
      }
      return {
        params: {
          tag: slugifiedTag
        }
      };
    })
    .filter(Boolean);
}

const currentTag = Astro.params.tag;

// Tìm tên tag gốc nguyên bản để hiển thị lên tiêu đề H1
const originalTag =
  posts
    .flatMap(post => post.frontmatter.tags || [])
    .find(tag => slugify(tag) === currentTag);

// Lọc bài viết thuộc tag này
const filteredPosts = posts.filter(post => {
  const tags = post.frontmatter.tags || [];
  return tags.some(tag => slugify(tag) === currentTag);
});

// Sắp xếp bài viết mới nhất lên đầu
filteredPosts.sort((a, b) => {
  const dateA = a.frontmatter?.date || "2000-01-01";
  const dateB = b.frontmatter?.date || "2000-01-01";
  return new Date(dateB) - new Date(dateA);
});

// Lấy danh sách các tag khác làm danh mục khám phá ở Sidebar
const allTags = Array.from(
  new Set(posts.flatMap(post => post.frontmatter.tags || []))
).filter(tag => slugify(tag) !== currentTag).slice(0, 8);
---

<BaseLayout title={`Chủ đề: ${originalTag || 'Phân loại'}`}>

  <div class="w-full bg-[#efefef] min-h-screen py-6 px-3 md:px-5">
    
    <main class="max-w-[1180px] mx-auto bg-white p-4 md:p-6 shadow-sm rounded-lg">

      <div class="mb-6 border-l-4 border-red-600 pl-4 py-1">
        <h1 class="text-[24px] md:text-[32px] font-bold text-gray-900 tracking-tight leading-none">
          #{originalTag || 'Danh mục'}
        </h1>
        <p class="text-gray-400 text-xs mt-1.5 font-medium">
          Tổng số: {filteredPosts.length} bài viết
        </p>
      </div>

      {/* Cấu trúc Grid Responsive thông minh */}
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-x-8 gap-y-12 items-start">
        
        {/* CỘT TRÁI (8 Cột): Danh sách bài viết */}
        <section class="lg:col-span-8 divide-y divide-gray-100 min-h-[700px]">
          {
            filteredPosts.map((post) => (
              <ArticleItem post={post} />
            ))
          }
          
          {
            filteredPosts.length === 0 && (
              <p class="text-sm text-gray-400 italic py-12 text-center">Chưa có nội dung nào thuộc chủ đề này.</p>
            )
          }
        </section>

        {/* CỘT PHẢI (4 Cột): Tự động dàn hàng dọc xuống dưới cùng trên Mobile và trượt dính trên PC */}
        <aside class="lg:col-span-4 w-full h-full">
          
          {/* LỚP BỌC CON: Xử lý lg:sticky mượt mà trên máy tính */}
          <div class="lg:sticky lg:top-6 space-y-6">
            
            {/* Khối danh mục khám phá nhanh */}
            <div class="bg-gray-50/60 p-4 rounded-xl border border-gray-100">
              <div class="border-l-4 border-red-600 pl-3 mb-4">
                <h2 class="font-bold text-[18px] text-gray-900 tracking-tight">
                  Chủ đề nổi bật
                </h2>
              </div>
              <div class="flex flex-wrap gap-2">
                {allTags.map((tag) => (
                  <a
                    href={`/tags/${slugify(tag)}`}
                    class="bg-white hover:bg-red-50 text-gray-600 hover:text-red-600 px-3 py-1.5 rounded-lg text-xs font-medium border border-gray-200/60 transition-all shadow-sm"
                  >
                    #{tag}
                  </a>
                ))}
              </div>
            </div>

            {/* Khối Quảng cáo */}
            <SidebarAd />

          </div>
          
        </aside>

      </div>

    </main>
    
  </div>

</BaseLayout>