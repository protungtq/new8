---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleItem from "../components/ArticleItem.astro";

const POSTS_PER_PAGE = 10;

const rawPosts = Object.entries(
  import.meta.glob('../content/posts/*.md', {
    eager: true
  })
);

const now = new Date(); // Lấy mốc thời gian hiện tại lúc hệ thống build trang

// 1. Lọc và chuẩn hóa danh sách bài viết đã xuất bản
const posts = rawPosts
  .map(([path, post]) => {
    if (!post || !post.frontmatter) {
      return null;
    }
    const slug = path
      .split('/')
      .pop()
      .replace('.md', '');

    return {
      slug,
      frontmatter: post.frontmatter
    };
  })
  .filter(Boolean)
  .filter((post) => {
    if (!post.frontmatter.date) return false;
    return new Date(post.frontmatter.date) <= now;
  });

// Sắp xếp bài viết mới nhất lên đầu cho luồng chính
posts.sort((a, b) => {
  const dateA = a.frontmatter?.date || "2000-01-01";
  const dateB = b.frontmatter?.date || "2000-01-01";
  return new Date(dateB) - new Date(dateA);
});

// TÁCH BÀI ĐẦU TIÊN LÀM TIN TIÊU ĐIỂM TO NHẤT
const featuredPost = posts[0];
// Các bài viết còn lại xếp ở lưới phía dưới
const remainingPosts = posts.slice(1, POSTS_PER_PAGE);

// 2. LẤY NGẪU NHIÊN TIN TRONG 7 NGÀY QUA CHO SIDEBAR
const SEVEN_DAYS_AGO = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);

const randomPosts = posts
  .filter((post) => {
    if (!post.frontmatter.date) return false;
    const postDate = new Date(post.frontmatter.date);
    return postDate >= SEVEN_DAYS_AGO && postDate <= now;
  })
  .sort(() => 0.5 - Math.random())
  .slice(0, 5);

// Hàm định dạng ngày nhanh
const formatShortDate = (dateString) => {
  if (!dateString) return "";
  try {
    return new Date(dateString).toLocaleDateString("vi-VN", {
      day: "2-digit",
      month: "2-digit",
      year: "numeric"
    });
  } catch (e) {
    return dateString;
  }
};
---

<BaseLayout title="Game News">
  <main class="max-w-[1180px] mx-auto bg-white min-h-screen px-4 md:px-6 py-6 shadow-sm rounded-b-xl">
    
    {featuredPost && (
      <section class="mb-8 border-b border-gray-100 pb-8">
        <a href={`/posts/${featuredPost.slug}`} class="group block md:grid md:grid-cols-12 md:gap-6 items-center">
          <div class="md:col-span-7 overflow-hidden rounded-xl border border-gray-100 bg-gray-50 aspect-[16/9] md:aspect-[16/10]">
            <img 
              src={featuredPost.frontmatter.image} 
              alt={featuredPost.frontmatter.title} 
              class="w-full h-full object-cover group-hover:scale-[1.01] transition-transform duration-500"
            />
          </div>
          <div class="md:col-span-5 mt-4 md:mt-0 flex flex-col justify-center">
            <span class="inline-block bg-red-50 text-red-600 font-bold text-[11px] px-2.5 py-1 rounded-full uppercase tracking-wider w-fit mb-3">
              Tin tiêu điểm
            </span>
            <h2 class="font-extrabold text-[22px] md:text-[28px] leading-tight text-gray-900 group-hover:text-red-600 transition-colors duration-200">
              {featuredPost.frontmatter.title}
            </h2>
            <p class="text-xs text-gray-400 mt-2">{formatShortDate(featuredPost.frontmatter.date)}</p>
            <p class="text-gray-500 text-[14px] leading-relaxed mt-3 line-clamp-3 md:line-clamp-4">
              {featuredPost.frontmatter.description}
            </p>
          </div>
        </a>
      </section>
    )}

    <div class="grid grid-cols-1 md:grid-cols-12 md:gap-8 items-start">
      
      <section class="md:col-span-8">
        <div class="border-b-2 border-gray-900 pb-2 mb-4">
          <h2 class="font-bold text-[18px] uppercase tracking-wider text-gray-900">Mới cập nhật</h2>
        </div>
        
        <div class="divide-y divide-gray-100">
          {remainingPosts.map((post) => (
            <ArticleItem post={post} />
          ))}
        </div>

        {posts.length > POSTS_PER_PAGE && (
          <div class="mt-8 flex justify-center">
            <a
              href="/page/2"
              class="bg-gray-50 border border-gray-200 text-gray-700 hover:bg-red-600 hover:text-white hover:border-red-600 px-12 py-3 rounded-lg font-semibold transition-all duration-200 shadow-sm"
            >
              Xem thêm bài viết
            </a>
          </div>
        )}
      </section>

      <aside class="hidden lg:block lg:col-span-4 sticky top-6 bg-gray-50/60 p-4 rounded-xl border border-gray-100">
        <div class="border-l-4 border-red-600 pl-3 mb-5">
          <h2 class="font-bold text-[20px] text-gray-900 tracking-tight">
            Khám phá trong tuần
          </h2>
        </div>

        <div class="space-y-4">
          {randomPosts.map((post, index) => (
            <a
              href={`/posts/${post.slug}`}
              class="group flex gap-3 items-center border-b border-gray-200/60 pb-3 last:border-0 last:pb-0"
            >
              <div class="flex-shrink-0 w-6 h-6 flex items-center justify-center font-bold text-xs bg-gray-200/80 text-gray-600 rounded-md group-hover:bg-red-600 group-hover:text-white transition-colors">
                {index + 1}
              </div>
              <div class="min-w-0">
                <h3 class="font-bold leading-snug text-[14px] text-gray-800 group-hover:text-red-600 transition-colors duration-200 line-clamp-2">
                  {post.frontmatter.title}
                </h3>
              </div>
            </a>
          ))}
          
          {randomPosts.length === 0 && (
            <p class="text-xs text-gray-400 italic py-2">Chưa có bài viết mới nào trong 7 ngày qua.</p>
          )}
        </div>
      </aside>

    </div>
  </main>
</BaseLayout>