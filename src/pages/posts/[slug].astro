---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { slugify } from "../../utils/slugify";

const postModules = import.meta.glob(
  '../../content/posts/*.md',
  { eager: true }
);

export async function getStaticPaths() {
  const now = new Date();
  const posts = Object.entries(
    import.meta.glob(
      '../../content/posts/*.md',
      { eager: true }
    )
  );

  return posts.map(([path, post]) => {
    const slug = path
      .split('/')
      .pop()
      .replace('.md', '');

    return {
      params: { slug },
      props: { post }
    };
  });
}

const { post } = Astro.props;
const { Content, frontmatter } = post;

// KHÓA TRUY CẬP TRỰC TIẾP: Nếu bài viết thuộc tương lai, chuyển hướng hoặc thông báo lỗi
const now = new Date();
const isFuturePost = frontmatter?.date ? new Date(frontmatter.date) > now : false;

// Gom danh sách bài viết liên quan (Chỉ lấy các bài viết đã công khai)
const allPosts = Object.entries(postModules)
  .map(([path, item]) => {
    if (!item || !item.frontmatter) return null;
    const slug = path.split('/').pop().replace('.md', '');
    return { slug, frontmatter: item.frontmatter };
  })
  .filter(Boolean)
  .filter((item) => {
    if (!item.frontmatter.date) return false;
    return new Date(item.frontmatter.date) <= now;
  });

allPosts.sort((a, b) => new Date(b.frontmatter.date) - new Date(a.frontmatter.date));
const relatedPosts = allPosts.slice(0, 4);
---

<BaseLayout title={isFuturePost ? "Nội dung chưa được công khai" : frontmatter.title} description={frontmatter.description} image={frontmatter.image}>
  
  <main class=\"max-w-[1180px] mx-auto bg-white min-h-screen px-3 md:px-5 py-5\">
    {
      isFuturePost ? (
        // Giao diện hiển thị nếu có người cố tình vào link bài viết chưa đến giờ đăng
        <div class=\"text-center py-20\">
          <h1 class=\"text-2xl font-bold text-red-600\">Nội dung chưa công khai</h1>
          <p class=\"text-gray-500 mt-2\">Bài viết này đã được lên lịch và sẽ tự động mở truy cập khi đến thời gian quy định.</p>
          <a href=\"/\" class=\"inline-block mt-6 bg-red-600 text-white px-6 py-2 rounded font-semibold\">Quay lại trang chủ</a>
        </div>
      ) : (
        // Giao diện hiển thị bài viết bình thường
        <article class=\"max-w-[800px] mx-auto\">
          <header class=\"mb-6\">
            <h1 class=\"text-[28px] md:text-[36px] font-bold leading-tight\">
              {frontmatter.title}
            </h1>
            <p class=\"text-sm text-gray-500 mt-2\">
              Xuất bản: {frontmatter.date}
            </p>
          </header>

          <div class=\"prose max-w-none leading-relaxed text-[16px] md:text-[18px]\">
            <Content />
          </div>

          {
            relatedPosts.length > 0 && (
              <section class=\"mt-12 border-t pt-8\">
                <div class=\"border-l-4 border-red-600 pl-3 mb-6\">
                  <h2 class=\"text-xl font-bold\">Tin liên quan</h2>
                </div>
                <div class=\"space-y-5\">
                  {
                    relatedPosts.map((item) => (
                      <a href={`/posts/${item.slug}`} class=\"flex gap-4 border-b pb-5\">
                        <img src={item.frontmatter.image} alt={item.frontmatter.title} class=\"w-[120px] h-[72px] md:w-[220px] md:h-[124px] object-cover flex-shrink-0\" />
                        <div>
                          <h3 class=\"font-bold text-[18px] leading-6 md:text-[24px] md:leading-8\">
                            {item.frontmatter.title}
                          </h3>
                        </div>
                      </a>
                    ))
                  }
                </div>
              </section>
            )
          }
        </article>
      )
    }
  </main>

</BaseLayout>