---
import BaseLayout from "../../layouts/BaseLayout.astro"; // [cite: 12]
import { slugify } from "../../utils/slugify"; // [cite: 12]

const postModules = import.meta.glob(
  '../../content/posts/*.md', // [cite: 13]
  { eager: true } // [cite: 13]
);

export async function getStaticPaths() {
  const posts = Object.entries(
    import.meta.glob( // [cite: 14]
      '../../content/posts/*.md', // [cite: 14]
      { eager: true } // [cite: 14]
    )
  );

  return posts.map(([path, post]) => { // [cite: 15]
    const slug = path // [cite: 15]
      .split('/')
      .pop()
      .replace('.md', ''); // [cite: 15]

    return { // [cite: 15]
      params: { slug }, // [cite: 15]
      props: { post } // [cite: 15]
    }; // [cite: 15]
  }); // [cite: 15]
}

const { post } = Astro.props; // [cite: 16]
const { Content, frontmatter } = post; // [cite: 16]

const now = new Date();
const isFuturePost = frontmatter?.date ? new Date(frontmatter.date) > now : false;

const allPosts = Object.entries(postModules) // [cite: 17]
  .map(([path, item]) => { // [cite: 17]
    if (!item || !item.frontmatter) return null; // [cite: 17]
    const slug = path.split('/').pop().replace('.md', ''); // [cite: 17]
    return { slug, frontmatter: item.frontmatter }; // [cite: 17]
  })
  .filter(Boolean) // [cite: 17]
  .filter((item) => new Date(item.frontmatter.date) <= now);

const currentTags = frontmatter?.tags || []; // [cite: 18]

const relatedPosts = allPosts // [cite: 18]
  .filter((item) => {
    if (item.slug === Astro.params.slug) return false; // [cite: 18]
    const tags = item.frontmatter?.tags || []; // [cite: 18]
    return tags.some(tag => // [cite: 18]
      currentTags.map(t => t.toLowerCase()).includes(tag.toLowerCase()) // [cite: 18]
    );
  })
  .slice(0, 5); // [cite: 18]

const formatShortDate = (dateString) => {
  if (!dateString) return "";
  try {
    return new Date(dateString).toLocaleDateString("vi-VN", {
      day: "2-digit",
      month: "2-digit",
      year: "numeric"
    });
  } catch (e) {
    return dateString;
  }
};
---

<BaseLayout
  title={isFuturePost ? "Nội dung chưa công khai" : frontmatter.title}
  description={frontmatter.description} // [cite: 19]
  image={frontmatter.image} // [cite: 19]
>
  <div class="w-full bg-[#efefef] min-h-screen py-6 px-3 md:px-5">
    <main class="max-w-[1180px] mx-auto bg-white p-4 md:p-6 shadow-sm rounded-lg">
      
      {isFuturePost ? (
        <div class="text-center py-20">
          <h1 class="text-2xl font-bold text-red-600">Nội dung chưa công khai</h1>
          <p class="text-gray-500 mt-2">Bài viết này đã được lên lịch và sẽ tự động hiển thị khi đến thời gian quy định.</p>
          <a href="/" class="inline-block mt-6 bg-red-600 text-white px-6 py-2 rounded font-semibold">Quay lại trang chủ</a>
        </div>
      ) : (
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
          
          <article class="lg:col-span-8 w-full min-w-0 overflow-hidden">
            <h1 class="text-[24px] md:text-[32px] font-bold text-gray-900 leading-tight tracking-tight">
              {frontmatter.title} {/* [cite: 19] */}
            </h1>

            <div class="text-xs text-gray-400 mt-3 flex items-center gap-2 border-b border-gray-100 pb-3">
              <span class="font-bold text-gray-700 uppercase">Nội dung chuyên sâu</span>
              <span>•</span>
              <span>{formatShortDate(frontmatter.date)}</span> {/* [cite: 19] */}
            </div>

            <div class="mt-5 w-full overflow-hidden rounded-lg bg-gray-100 aspect-[16/9]">
              <img
                src={frontmatter.image} // [cite: 20]
                alt={frontmatter.title} // [cite: 20]
                class="w-full h-full object-cover block"
              />
            </div>

            <div class="custom-markdown-content mt-6 text-[#222] text-[16px] md:text-[17px] leading-relaxed space-y-4">
              <Content />
            </div>

            {currentTags.length > 0 && ( // [cite: 21]
              <div class="mt-8 pt-4 border-t border-gray-100 flex flex-wrap gap-2"> {/* [cite: 21] */}
                {currentTags.map((tag) => ( // [cite: 21]
                  <a
                    href={`/tags/${slugify(tag)}`} // [cite: 21]
                    class="bg-gray-100 hover:bg-red-50 text-gray-600 hover:text-red-600 px-2.5 py-1 rounded text-xs font-medium border border-gray-200 transition-all"
                  >
                    #{tag} {/* [cite: 23] */}
                  </a>
                ))}
              </div>
            )}
          </article>

          <aside class="hidden lg:block lg:col-span-4 sticky top-6 bg-gray-50/50 p-4 rounded-xl border border-gray-100"> {/* [cite: 24] */}
            <div class="border-l-4 border-red-600 pl-3 mb-4">
              <h2 class="font-bold text-[18px] text-gray-900 tracking-tight"> {/* [cite: 24] */}
                Bài viết liên quan
              </h2>
            </div>

            <div class="space-y-4">
              {relatedPosts.map((item) => ( // [cite: 25]
                <a
                  href={`/posts/${item.slug}`} // [cite: 25]
                  class="group flex gap-3 items-start border-b border-gray-200/50 pb-3 last:border-0 last:pb-0"
                >
                  <div class="w-20 h-14 flex-shrink-0 overflow-hidden rounded bg-gray-200 aspect-[4/3]">
                    <img
                      src={item.frontmatter.image} // [cite: 27]
                      alt={item.frontmatter.title} // [cite: 27]
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                  </div>

                  <div class="min-w-0">
                    <h3 class="font-bold text-[13px] leading-snug text-gray-800 group-hover:text-red-600 transition-colors duration-200 line-clamp-2"> {/* [cite: 30] */}
                      {item.frontmatter.title} {/* [cite: 30] */}
                    </h3>
                    <p class="text-[10px] text-gray-400 mt-1">{formatShortDate(item.frontmatter.date)}</p> {/* [cite: 33] */}
                  </div>
                </a>
              ))}

              {relatedPosts.length === 0 && (
                <p class="text-xs text-gray-400 italic py-2">Không có nội dung liên quan nào khác.</p>
              )}
            </div>
          </aside>

        </div>
      )}
    </main>
  </div>
</BaseLayout>

<style is:global>
  .custom-markdown-content p {
    margin-bottom: 1.25rem;
    color: #2b2b2b;
    text-align: justify;
  }
  .custom-markdown-content h2 {
    font-size: 20px;
    font-weight: 700;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    color: #111;
  }
  .custom-markdown-content h3 {
    font-size: 18px;
    font-weight: 700;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: #222;
  }
  .custom-markdown-content img {
    max-width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 8px;
    margin: 1.5rem auto;
    display: block;
  }
  .custom-markdown-content ul, .custom-markdown-content ol {
    margin-left: 1.5rem;
    margin-bottom: 1.25rem;
    list-style-type: disc;
  }
  .custom-markdown-content li {
    margin-bottom: 0.25rem;
  }
</style>