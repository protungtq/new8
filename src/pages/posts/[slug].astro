---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { slugify } from "../../utils/slugify";
// IMPORTANT:
// phải khai báo glob bên ngoài
const postModules = import.meta.glob(
  '../../content/posts/*.md',
  { eager: true }
);

// static paths
export async function getStaticPaths() {

  const posts = Object.entries(
    import.meta.glob(
      '../../content/posts/*.md',
      { eager: true }
    )
  );

  return posts.map(([path, post]) => {

    const slug = path
      .split('/')
      .pop()
      .replace('.md', '');

    return {
      params: { slug },
      props: { post }
    };

  });

}

const { post } = Astro.props;

const {
  Content,
  frontmatter
} = post;

// related posts
const allPosts = Object.entries(postModules)
  .map(([path, item]) => {

    if (!item || !item.frontmatter) {
      return null;
    }

    const slug = path
      .split('/')
      .pop()
      .replace('.md', '');

    return {
      slug,
      frontmatter: item.frontmatter
    };

  })
  .filter(Boolean);

const currentTags =
  frontmatter?.tags || [];

const relatedPosts = allPosts
  .filter((item) => {

    if (item.slug === Astro.params.slug) {
      return false;
    }

    const tags =
      item.frontmatter?.tags || [];

    return tags.some(tag =>
      currentTags
        .map(t => t.toLowerCase())
        .includes(tag.toLowerCase())
    );

  })
  .slice(0, 4);
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  image={frontmatter.image}
  canonical={`https://news.so1.asia/posts/${Astro.params.slug}`}
>

  <main class="max-w-[1180px] mx-auto bg-white min-h-screen px-3 md:px-5 py-6">

    <article class="max-w-[860px]">

      <!-- title -->
      <h1 class="text-[30px] md:text-[42px] leading-[1.3] font-bold">

        {frontmatter.title}

      </h1>

      <!-- meta -->
      <div class="text-sm text-gray-500 mt-3">

        {frontmatter.date}

      </div>

      <!-- image -->
      <img
        src={frontmatter.image}
        alt={frontmatter.title}
        class="w-full mt-6"
      />

      <!-- content -->
      <div class="prose max-w-none mt-8">

        <Content />

      </div>

      <!-- tags -->
      {
        currentTags.length > 0 && (

          <div class="mt-10 flex flex-wrap gap-3 border-t pt-6">

            {
              currentTags.map((tag) => (

                <a
                  href={`/tags/${slugify(tag)}`}
                  class="
                    bg-[#efefef]
                    px-4
                    py-2
                    text-[15px]
                    font-semibold
                  "
                >

                  #{tag}

                </a>

              ))
            }

          </div>

        )
      }

      <!-- related -->
      {
        relatedPosts.length > 0 && (

          <section class="mt-14 border-t pt-8">

            <h2 class="text-[26px] md:text-[34px] font-bold mb-8">

              Bài liên quan

            </h2>

            <div class="space-y-6">

              {
                relatedPosts.map((item) => (

                  <a
                    href={`/posts/${item.slug}`}
                    class="
                      flex
                      gap-4
                      border-b
                      pb-5
                    "
                  >

                    <img
                      src={item.frontmatter.image}
                      alt={item.frontmatter.title}
                      class="
                        w-[120px]
                        h-[72px]
                        md:w-[220px]
                        md:h-[124px]
                        object-cover
                        flex-shrink-0
                      "
                    />

                    <div>

                      <h3
                        class="
                          font-bold
                          text-[18px]
                          leading-6
                          md:text-[28px]
                          md:leading-[36px]
                        "
                      >

                        {item.frontmatter.title}

                      </h3>

                      <p class="text-sm text-gray-500 mt-2">

                        {item.frontmatter.date}

                      </p>

                    </div>

                  </a>

                ))
              }

            </div>

          </section>

        )
      }

    </article>

  </main>

</BaseLayout>