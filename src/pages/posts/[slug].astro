---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { slugify } from "../../utils/slugify";

const postModules = import.meta.glob(
  '../../content/posts/*.md',
  { eager: true }
);

export async function getStaticPaths() {
  const now = new Date();
  const posts = Object.entries(
    import.meta.glob(
      '../../content/posts/*.md',
      { eager: true }
    )
  );

  return posts.map(([path, post]) => {
    const slug = path
      .split('/')
      .pop()
      .replace('.md', '');

    return {
      params: { slug },
      props: { post }
    };
  });
}

const { post } = Astro.props;
const { Content, frontmatter } = post;

// Bộ lọc bảo mật bài viết tương lai
const now = new Date();
const isFuturePost = frontmatter?.date ? new Date(frontmatter.date) > now : false;

// Đọc tất cả bài viết để làm tài nguyên lọc bài liên quan (Chỉ lấy bài đã xuất bản)
const allPosts = Object.entries(postModules)
  .map(([path, item]) => {
    if (!item || !item.frontmatter) return null;
    const slug = path.split('/').pop().replace('.md', '');
    return { slug, frontmatter: item.frontmatter };
  })
  .filter(Boolean)
  .filter((item) => new Date(item.frontmatter.date) <= now);

const currentTags = frontmatter?.tags || [];

// Lọc ra tối đa 5 bài viết có cùng từ khóa (loại trừ bài hiện tại)
const relatedPosts = allPosts
  .filter((item) => {
    if (item.slug === Astro.params.slug) return false;
    const tags = item.frontmatter?.tags || [];
    return tags.some(tag =>
      currentTags.map(t => t.toLowerCase()).includes(tag.toLowerCase())
    );
  })
  .slice(0, 5);

// Hàm định dạng ngày hiển thị thân thiện cho Sidebar
const formatShortDate = (dateString) => {
  if (!dateString) return "";
  try {
    return new Date(dateString).toLocaleDateString("vi-VN", {
      day: "2-digit",
      month: "2-digit",
      year: "numeric"
    });
  } catch (e) {
    return dateString;
  }
};
---

<BaseLayout
  title={isFuturePost ? "Nội dung chưa công khai" : frontmatter.title}
  description={frontmatter.description}
  image={frontmatter.image}
  canonical={`https://news.so1.asia/posts/${Astro.params.slug}`}
>
  <main class="max-w-[1180px] mx-auto bg-white min-h-screen px-4 md:px-6 py-6 shadow-sm rounded-b-xl">
    
    {isFuturePost ? (
      <div class="text-center py-20">
        <h1 class="text-2xl font-bold text-red-600">Nội dung chưa công khai</h1>
        <p class="text-gray-500 mt-2">Bài viết này đã được lên lịch và sẽ tự động mở khi đến thời gian quy định.</p>
        <a href="/" class="inline-block mt-6 bg-red-600 text-white px-6 py-2 rounded-lg font-semibold hover:bg-red-700 transition-colors">Quay lại trang chủ</a>
      </div>
    ) : (
      /* BỐ CỤC LƯỚI: Chia 8 cột nội dung và 4 cột Sidebar trên màn hình lớn */
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        <article class="lg:col-span-8 min-w-0">
          
          <h1 class="text-[26px] md:text-[36px] leading-tight font-extrabold text-gray-900 tracking-tight">
            {frontmatter.title}
          </h1>

          <div class="text-xs text-gray-400 mt-3 flex items-center gap-2 border-b border-gray-100 pb-4">
            <span class="font-semibold text-red-600 uppercase">Tin tức</span>
            <span>•</span>
            <span>{formatShortDate(frontmatter.date)}</span>
          </div>

          <div class="mt-6 overflow-hidden rounded-xl bg-gray-50 border border-gray-100 aspect-[16/9]">
            <img
              src={frontmatter.image}
              alt={frontmatter.title}
              class="w-full h-full object-cover"
            />
          </div>

          <div class="prose max-w-none mt-6 text-gray-800 leading-relaxed text-[16px] md:text-[17px] space-y-4">
            <Content />
          </div>

          {currentTags.length > 0 && (
            <div class="mt-8 pt-4 border-t border-gray-100 flex flex-wrap gap-2">
              {currentTags.map((tag) => (
                <a
                  href={`/tags/${slugify(tag)}`}
                  class="bg-gray-50 hover:bg-red-50 text-gray-600 hover:text-red-600 px-3 py-1.5 rounded-md text-xs font-medium border border-gray-200/60 hover:border-red-200 transition-all"
                >
                  #{tag}
                </a>
              ))}
            </div>
          )}
        </article>

        <aside class="hidden lg:block lg:col-span-4 sticky top-6">
          <div class="border-l-4 border-red-600 pl-3 mb-5">
            <h2 class="font-extrabold text-[20px] tracking-tight text-gray-900">
              Tin cùng từ khóa
            </h2>
          </div>

          <div class="space-y-4">
            {relatedPosts.map((item) => (
              <a
                href={`/posts/${item.slug}`}
                class="group flex gap-3 items-center border-b border-gray-50 pb-3 last:border-0"
              >
                <div class="w-20 h-14 flex-shrink-0 overflow-hidden rounded-lg bg-gray-50 border border-gray-100">
                  <img
                    src={item.frontmatter.image}
                    alt={item.frontmatter.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                </div>

                <div class="min-w-0">
                  <h3 class="font-bold text-[13.5px] leading-snug text-gray-800 group-hover:text-red-600 transition-colors duration-200 line-clamp-2">
                    {item.frontmatter.title}
                  </h3>
                  <p class="text-[11px] text-gray-400 mt-1">{formatShortDate(item.frontmatter.date)}</p>
                </div>
              </a>
            ))}

            {relatedPosts.length === 0 && (
              <p class="text-xs text-gray-400 italic py-4">Không có bài viết nào khác có cùng từ khóa này.</p>
            )}
          </div>
        </aside>

      </div>
    )}
  </main>
</BaseLayout>