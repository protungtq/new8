---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleItem from "../../components/ArticleItem.astro";

const POSTS_PER_PAGE = 10;

const rawPosts = Object.entries(
  import.meta.glob('../../content/posts/*.md', { eager: true })
);

const posts = rawPosts.map(([path, post]) => {

  const slug = path
    .split('/')
    .pop()
    .replace('.md', '');

  return {
    slug,
    frontmatter: post.frontmatter
  };
});

posts.sort(
  (a, b) =>
    new Date(b.frontmatter.date) - new Date(a.frontmatter.date)
);

const totalPages = Math.ceil(
  posts.length / POSTS_PER_PAGE
);

export async function getStaticPaths() {

  const rawPosts = Object.entries(
    import.meta.glob('../../content/posts/*.md', { eager: true })
  );

  const totalPages = Math.ceil(
    rawPosts.length / 10
  );

  return Array.from(
    { length: totalPages },
    (_, i) => ({
      params: {
        page: String(i + 1)
      }
    })
  );
}

const currentPage = Number(Astro.params.page);

const start = (currentPage - 1) * POSTS_PER_PAGE;

const visiblePosts = posts.slice(
  start,
  start + POSTS_PER_PAGE
);
---

<BaseLayout title={`Trang ${currentPage} - Game News`}>

  <main class="max-w-[1180px] mx-auto bg-white min-h-screen px-3 md:px-5 py-5">

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

      <!-- Feed -->
      <section class="lg:col-span-8">

        {
          visiblePosts.map((post) => (
            <ArticleItem post={post} />
          ))
        }

        <!-- Pagination -->
        <div class="flex justify-center gap-3 mt-8">

          {
            currentPage > 1 && (

              <a
                href={
                  currentPage === 2
                    ? "/"
                    : `/page/${currentPage - 1}`
                }
                class="bg-[#e5e5e5] px-6 py-3"
              >
                Trang trước
              </a>

            )
          }

          {
            currentPage < totalPages && (

              <a
                href={`/page/${currentPage + 1}`}
                class="bg-[#e5e5e5] px-6 py-3"
              >
                Xem thêm
              </a>

            )
          }

        </div>

      </section>

      <!-- Sidebar -->
      <aside class="lg:col-span-4 mt-8 lg:mt-0">

        <div class="border-l-4 border-red-600 pl-3 mb-5">

          <h2 class="font-bold text-[22px] md:text-[28px] leading-none">
            Đọc nhiều
          </h2>

        </div>

        <div class="space-y-4">

          {
            posts.slice(0, 5).map((post, index) => (

              <a
                href={`/posts/${post.slug}`}
                class="flex gap-3 border-b pb-3"
              >

                <div class="text-red-600 font-bold text-2xl w-6">
                  {index + 1}
                </div>

                <div>

                  <h3 class="font-bold leading-6 text-[17px]">
                    {post.frontmatter.title}
                  </h3>

                  <p class="text-sm text-gray-500 mt-1">
                    {post.frontmatter.date}
                  </p>

                </div>

              </a>

            ))
          }

        </div>

      </aside>

    </div>

  </main>

</BaseLayout>