---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleItem from "../../components/ArticleItem.astro";

const POSTS_PER_PAGE = 10;

const rawPosts = Object.entries(
  import.meta.glob('../../content/posts/*.md', { eager: true })
);

const posts = rawPosts.map(([path, post]) => {
  const slug = path
    .split('/')
    .pop()
    .replace('.md', '');

  return {
    slug,
    frontmatter: post.frontmatter
  };
});

posts.sort(
  (a, b) => new Date(b.frontmatter.date) - new Date(a.frontmatter.date)
);

const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);

export async function getStaticPaths() {
  const rawPosts = Object.entries(
    import.meta.glob('../../content/posts/*.md', { eager: true })
  );
  const totalPages = Math.ceil(rawPosts.length / 10);

  return Array.from(
    { length: totalPages },
    (_, i) => ({
      params: {
        page: String(i + 1)
      }
    })
  );
}

const currentPage = Number(Astro.params.page);
const start = (currentPage - 1) * POSTS_PER_PAGE;
const end = start + POSTS_PER_PAGE;
const visiblePosts = posts.slice(start, end);

const popularPosts = posts.slice(0, 5);

const formatShortDate = (dateString) => {
  if (!dateString) return "";
  try {
    return new Date(dateString).toLocaleDateString("vi-VN", {
      day: "2-digit",
      month: "2-digit",
      year: "numeric"
    });
  } catch (e) {
    return dateString;
  }
};
---

<BaseLayout title={`Trang ${currentPage} - Game News`}>
  <main class="max-w-[1180px] mx-auto bg-white min-h-screen px-4 md:px-6 py-6 shadow-sm rounded-b-xl">
    
    <div class="grid grid-cols-1 md:grid-cols-12 md:gap-8 items-start">
      
      <section class="md:col-span-8">
        <div class="border-b-2 border-gray-900 pb-2 mb-4">
          <h2 class="font-bold text-[18px] uppercase tracking-wider text-gray-900">Trang {currentPage}</h2>
        </div>

        <div class="divide-y divide-gray-100">
          {visiblePosts.map((post) => (
            <ArticleItem post={post} />
          ))}
        </div>

        <div class="mt-8 flex justify-center gap-4">
          {currentPage > 1 && (
            <a
              href={currentPage === 2 ? "/" : `/page/${currentPage - 1}`}
              class="bg-gray-50 border border-gray-200 text-gray-700 hover:bg-gray-900 hover:text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition-all shadow-sm"
            >
              &larr; Trang trước
            </a>
          )}

          {currentPage < totalPages && (
            <a
              href={`/page/${currentPage + 1}`}
              class="bg-gray-50 border border-gray-200 text-gray-700 hover:bg-red-600 hover:text-white hover:border-red-600 px-8 py-2.5 rounded-lg text-sm font-semibold transition-all shadow-sm"
            >
              Xem thêm &rarr;
            </a>
          )}
        </div>
      </section>

      <aside class="hidden lg:block lg:col-span-4 sticky top-6 mt-8 lg:mt-0">
        <div class="border-l-4 border-red-600 pl-3 mb-5">
          <h2 class="font-extrabold text-[22px] tracking-tight text-gray-900">
            Đọc nhiều
          </h2>
        </div>

        <div class="space-y-4">
          {popularPosts.map((post, index) => (
            <a
              href={`/posts/${post.slug}`}
              class="group flex gap-3 items-center border-b border-gray-50 pb-3 last:border-0"
            >
              <div class={`flex-shrink-0 w-7 h-7 flex items-center justify-center font-bold text-sm rounded-md transition-colors ${
                index < 3 ? 'bg-red-600 text-white' : 'bg-gray-100 text-gray-500'
              }`}>
                {index + 1}
              </div>

              <div class="w-14 h-14 flex-shrink-0 overflow-hidden rounded-md bg-gray-50 border border-gray-100">
                <img 
                  src={post.frontmatter.image} 
                  alt={post.frontmatter.title} 
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>

              <div class="min-w-0">
                <h3 class="font-bold text-[14px] leading-snug text-gray-800 group-hover:text-red-600 transition-colors duration-200 line-clamp-2">
                  {post.frontmatter.title}
                </h3>
                <p class="text-[11px] text-gray-400 mt-1">{formatShortDate(post.frontmatter.date)}</p>
              </div>
            </a>
          ))}
        </div>
      </aside>

    </div>
  </main>
</BaseLayout>