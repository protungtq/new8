---
const { post } = Astro.props; // [cite: 76]

const formatDate = (dateString) => {
  if (!dateString) return "";
  try {
    const date = new Date(dateString);
    return date.toLocaleDateString("vi-VN", {
      day: "2-digit",
      month: "2-digit",
      year: "numeric"
    });
  } catch (e) {
    return dateString;
  }
};

const displayDate = formatDate(post.frontmatter.date);
---

<a
  href={`/posts/${post.slug}`} // [cite: 76]
  class="group flex gap-4 py-5 border-b border-gray-100 last:border-0 transition-all duration-300"
>
  <div class="w-[120px] h-[72px] md:w-[220px] md:h-[124px] flex-shrink-0 overflow-hidden rounded-lg bg-gray-50 border border-gray-100">
    <img
      src={post.frontmatter.image} // [cite: 76]
      alt={post.frontmatter.title} // [cite: 76]
      loading="lazy" // [cite: 76]
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
  </div>

  <div class="min-w-0 flex flex-col justify-center">
    <h2
      class="
        font-bold
        text-[16px]
        leading-snug
        md:text-[22px]
        md:leading-[30px]
        text-gray-900
        group-hover:text-red-600
        transition-colors
        duration-200
        line-clamp-2
      "
    >
      {post.frontmatter.title} {/* [cite: 76] */}
    </h2>

    <p class="text-[12px] text-gray-400 mt-1.5">
      {displayDate}
    </p>

    <p
      class="
        hidden
        md:block
        text-[14px]
        leading-relaxed
        text-gray-500
        mt-2
        line-clamp-2
      "
    >
      {post.frontmatter.description} {/* [cite: 78] */}
    </p>
  </div>
</a>